{
  "productName": "MinimalTimer",
  "version": "0.1.0",
  "identifier": "com.minimaltimer.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label":       "main",
        "title":       "MinimalTimer",
        "width":       280,
        "height":      280,
        "resizable":   false,
        "decorations": false,
        "transparent": true,
        "shadow":      false
      },
      {
        "label":       "records",
        "url":         "records.html",
        "title":       "記録",
        "width":       360,
        "height":      460,
        "resizable":   false,
        "decorations": false,
        "transparent": true,
        "shadow":      false,
        "visible":     false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["../icon.ico"]
  }
}
